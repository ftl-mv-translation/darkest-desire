#: src-en/data/events_sector_ddantumbra.xml:3218
msgid ""
"data/events_sector_ddantumbra.xml$//event[@name=\"DDANTUMBRA_GRAVEDIGGERLOCATION\"]/choice[@req=\"dd_antumbra_genesisdefeated\""
