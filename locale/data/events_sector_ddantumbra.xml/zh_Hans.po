msgstr "不……你在撒谎……我……我相信父亲……"

#: src-en/data/events_sector_ddantumbra.xml:3038
msgid ""
"data/events_sector_ddantumbra.xml$//event[@name=\"DDANTUMBRA_SHATTEREDMEMORY\"]/choice[@req=\"dd_antumbra_genesisdefeated\""
" and "
"@lvl=\"0\"]/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"darkone_alignment\""
" and "
"@lvl=\"1\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/text"
