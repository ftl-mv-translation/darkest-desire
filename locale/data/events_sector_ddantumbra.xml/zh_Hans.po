msgid ""
"data/events_sector_ddantumbra.xml$//event[@name=\"START_DDANTUMBRA\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "我……看不见你，也……听不见你，可是……我能感觉到你！你就在那里，对不对？"

#: src-en/data/events_sector_ddantumbra.xml:299
msgid ""
"data/events_sector_ddantumbra.xml$//event[@name=\"START_DDANTUMBRA\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
