msgid ""
"data/events_sector_ddantumbra.xml$//event[@name=\"DDANTUMBRA_SHATTEREDMEMORY\"]/choice[@req=\"dd_antumbra_genesisdefeated\""
" and "
"@lvl=\"0\"]/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"darkone_alignment\""
" and "
"@lvl=\"1\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/event/choice[@req=\"darkone_alignment\"]/text"
