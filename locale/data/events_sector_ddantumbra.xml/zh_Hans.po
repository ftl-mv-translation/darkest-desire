"data/events_sector_ddantumbra.xml$//event[@name=\"START_DDANTUMBRA\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "……喂？能听见我说话吗？"

#: src-en/data/events_sector_ddantumbra.xml:295
msgid ""
"data/events_sector_ddantumbra.xml$//event[@name=\"START_DDANTUMBRA\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
