msgid ""
"data/events_sector_ddantumbra.xml$//event[@name=\"NEUTRAL_DDANTUMBRA_ANXIOUSBORNE\"]/choice[@req=\"dd_antumbra_genesisdefeated\""
" and @lvl=\"1\"]/text"
msgstr "..."

#: src-en/data/events_sector_ddantumbra.xml:1353
