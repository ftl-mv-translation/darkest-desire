#: src-en/data/events_sector_ddsoulplague.xml:1094
msgid ""
"data/events_sector_ddsoulplague.xml$//event[@name=\"STORELIST_DDSOULPLAGUE_SHELLOUTPOST\"]/choice[1]/event/choice[1]/event/choice[1]/text"
msgstr "呵。奇怪。那就交易吧！不问任何问题！"

#: src-en/data/events_sector_ddsoulplague.xml:1098
msgid ""
"data/events_sector_ddsoulplague.xml$//event[@name=\"STORELIST_DDSOULPLAGUE_SHELLOUTPOST\"]/choice[1]/event/choice[1]/event/choice[2]/text"
msgstr "不了。我不信这个。赶紧离开这里。"

#: src-en/data/events_sector_ddsoulplague.xml:1100
msgid ""
"data/events_sector_ddsoulplague.xml$//event[@name=\"STORELIST_DDSOULPLAGUE_SHELLOUTPOST\"]/choice[1]/event/choice[1]/event/choice[2]/event/text"
msgstr ""
