msgid ""
"data/events_sector_ddsoulplague.xml$//event[@name=\"NEBULA_QUEST_DDSOULPLAGUE_THEMINISTER_SERAPHIMPROPHET_FIGHT_WIN\"]/choice[@req=\"LIFE_SCANNER\"]/event/text"
