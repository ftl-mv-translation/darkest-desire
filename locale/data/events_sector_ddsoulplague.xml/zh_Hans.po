#: src-en/data/events_sector_ddsoulplague.xml:4553
msgid ""
"data/events_sector_ddsoulplague.xml$//event[@name=\"CLEARING_DDSOULPLAGUE_EPSILONREMAINS\"]/choice[2]/text"
