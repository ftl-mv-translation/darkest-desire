#: src-en/data/events_sector_ddsoulplague.xml:289
msgid ""
"data/events_sector_ddsoulplague.xml$//event[@name=\"NEBULA_STORELIST_DDSOULPLAGUE_FEDERATIONREMAINS_INVESTIGATION_MINORSUCCESS\"]/choice[2]/event/choice[1]/text"
