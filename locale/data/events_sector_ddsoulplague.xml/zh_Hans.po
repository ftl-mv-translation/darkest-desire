#: src-en/data/events_sector_ddsoulplague.xml:5043
msgid ""
"data/events_sector_ddsoulplague.xml$//event[@name=\"NEBULA_QUEST_DDSOULPLAGUE_THEMINISTER_SERAPHIMPROPHET_FIGHT_WIN\"]/choice[@req=\"sensors\"]/event/choice/text"
