#: src-en/data/events_sector_ddsoulplague.xml:2965
msgid ""
"data/events_sector_ddsoulplague.xml$//event[@name=\"NEBULA_NEUTRAL_DDSOULPLAGUE_HUNTINGGUILD\"]/choice/event/choice/event/choice[1]/event/choice[@req=\"dd_corruptor\"]/text"
msgstr ""

