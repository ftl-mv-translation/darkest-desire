msgid ""
"data/events_sector_ddcoremass.xml$//event[@name=\"START_DDCOREMASS\"]/choice/event/choice/event/choice/event/choice/event/choice[@req=\"dd_soulplague_coremass_hopesflamecharges\"]/event/choice/event/choice[2]/event/choice/text"
msgstr "那么，前进——前往核心！"

#: src-en/data/events_sector_ddcoremass.xml:120
msgid ""
"data/events_sector_ddcoremass.xml$//event[@name=\"START_DDCOREMASS\"]/choice/event/choice/event/choice/event/choice/event/choice[@req=\"dd_soulplague_coremass_hopesflamecharges\"]/event/choice/event/choice[3]/text"
msgstr "我能得到的慰藉……就是获得弹药。"

#: src-en/data/events_sector_ddcoremass.xml:122
msgid ""
"data/events_sector_ddcoremass.xml$//event[@name=\"START_DDCOREMASS\"]/choice/event/choice/event/choice/event/choice/event/choice[@req=\"dd_soulplague_coremass_hopesflamecharges\"]/event/choice/event/choice[3]/event/text"
