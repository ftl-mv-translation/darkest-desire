#: src-en/data/events_sector_ddcoremass.xml:4536
msgid ""
"data/events_sector_ddcoremass.xml$//event[@name=\"DDCOREMASS_EXIT_ALONE\"]/text"
msgstr "你再次抵达了这段惨痛旅程的出口……这一次，你会走出去吗？"

#: src-en/data/events_sector_ddcoremass.xml:4544
msgid ""
"data/events_sector_ddcoremass.xml$//event[@name=\"DDCOREMASS_EXIT\"]/beaconType/unvisitedTooltip"
