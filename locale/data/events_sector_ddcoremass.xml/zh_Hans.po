#: src-en/data/events_sector_ddcoremass.xml:133
msgid ""
"data/events_sector_ddcoremass.xml$//event[@name=\"START_DDCOREMASS\"]/choice/event/choice/event/choice/event/choice/event/choice[@req=\"dd_soulplague_coremass_hopesflamecharges\"]/event/choice/event/choice[4]/text"
msgstr "我能得到的慰藉……就是获得无人机零件。"

#: src-en/data/events_sector_ddcoremass.xml:135
msgid ""
"data/events_sector_ddcoremass.xml$//event[@name=\"START_DDCOREMASS\"]/choice/event/choice/event/choice/event/choice/event/choice[@req=\"dd_soulplague_coremass_hopesflamecharges\"]/event/choice/event/choice[4]/event/text"
msgstr ""
"火焰释放出的残余能量仿佛凝聚起来，涌入你的飞船内部。当这股力量渐渐消散时，你"
