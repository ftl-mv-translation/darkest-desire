#: src-en/data/events_sector_ddcoremass.xml:127
msgid ""
"data/events_sector_ddcoremass.xml$//event[@name=\"START_DDCOREMASS\"]/choice/event/choice/event/choice/event/choice/event/choice[@req=\"dd_soulplague_coremass_hopesflamecharges\"]/event/choice/event/choice[3]/event/choice/text"
