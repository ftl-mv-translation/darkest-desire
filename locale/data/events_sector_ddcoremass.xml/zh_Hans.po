#: src-en/data/events_sector_ddcoremass.xml:3998
msgid ""
"data/events_sector_ddcoremass.xml$//ship[@name=\"DDCOREMASS_EXIT_FIGHT_THEDEVOURER\"]/destroyed/text"
msgstr "最后一击刺穿了灵魂瘟疫吞噬者的心脏——它轰然爆裂，邪恶的躯体向四面八方飞散。这"
"头巨兽，已然倒下！"

#: src-en/data/events_sector_ddcoremass.xml:4001
msgid ""
"data/events_sector_ddcoremass.xml$//ship[@name=\"DDCOREMASS_EXIT_FIGHT_THEDEVOURER\"]/destroyed/choice/text"
