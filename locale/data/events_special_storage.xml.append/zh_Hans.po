"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[3]/event/choice[@req=\"BLUELIST_CREW_DDENLIGHTENED\"]/event/choice[2]/text"
msgstr "调查赐福馈赠仪式。"

#: src-en/data/events_special_storage.xml.append:3785
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[3]/event/choice[@req=\"BLUELIST_CREW_DDENLIGHTENED\"]/event/choice[2]/event/text"
msgstr ""
"赐福馈赠仪式：\n"
"该仪式允许你以任意数量的人类献祭作为贡品，向黑暗之神奉上。每一次以仪式之名进"
"行的人类献祭，包括用以启动仪式的第一次献祭（无论第一次是否为人类献祭），都会"
"让你在以下奖励中选择一项：隐匿圣卫无人机、为你已拥有的上述无人机提供恩惠，或"
"是强化它们已持有的恩惠效果。"

#: src-en/data/events_special_storage.xml.append:3788
