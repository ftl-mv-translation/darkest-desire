#: src-en/data/events_special_storage.xml.append:4132
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[9]/event/choice[@req=\"BLUELIST_DDLIGHTBORNE_EQUIPMENT\"]/event/choice[@req=\"dd_spookydivineremnantoooougotspooked\""
" and @lvl=\"0\"]/event/text"
msgstr ""
"圣神遗物仪式：\n"
"7777777777777777777777777777777777777777777777777777777777777777\n"
"\n"
"77777777777 第一天，他们背弃了真理。77777777777\n"
"\n"
"77777777777777777 第二天，抛弃了历法。77777777777777777\n"
"\n"
"777777777 从那之后，言语、价值、规则、意义……777777777\n"
"\n"
"777777 ……直到最后，在第七天……尊严。7777777\n"
"\n"
"777777777 曾经的光裔族，已然不复存在。777777777\n"
"\n"
"777 而那些窃取了他们本源的诸神……77\n"
"\n"
"77 ……也理应化为虚无，只余下遥远的过往回响。7\n"
"\n"
"7777777777777777777777777777777777777777777777777777777777777777"

#: src-en/data/events_special_storage.xml.append:4152
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[9]/event/choice[@req=\"BLUELIST_DDLIGHTBORNE_EQUIPMENT\"]/event/choice[@req=\"dd_spookydivineremnantoooougotspooked\""
