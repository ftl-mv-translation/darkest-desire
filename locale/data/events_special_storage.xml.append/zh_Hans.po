#: src-en/data/events_special_storage.xml.append:3997
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[7]/event/choice[@req=\"pilot\"]/text"
msgstr "合上这本书。"

#: src-en/data/events_special_storage.xml.append:4003
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/text"
msgstr "调查那片虹彩般的七彩文字——腐化低语。"

#: src-en/data/events_special_storage.xml.append:4005
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/event/text"
msgstr "虽然你无法读懂这段文字，但本节的图示展现了异变与腐朽，以及万物的熵灭。你必须"
"找到能读懂这段文字的人，才能施展其中的仪式。"

#: src-en/data/events_special_storage.xml.append:4007
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/event/choice[@req=\"LIST_DDSOULPLAGUE_ALIGNED\"]/text"
msgstr "(灵魂瘟疫船员) 让你效忠于灵魂瘟疫的船员誊写这段文字。"

#: src-en/data/events_special_storage.xml.append:4009
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/event/choice[@req=\"LIST_DDSOULPLAGUE_ALIGNED\"]/event/text"
msgstr "你效忠于灵魂瘟疫的船员触碰了相关书页，上面的文字瞬间变得清晰可辨。你得以理解"
"这些页面的内容：数个记述着灵魂瘟疫物质病毒扩散与强化其力量的仪式。"

#: src-en/data/events_special_storage.xml.append:4011
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/event/choice[@req=\"LIST_DDSOULPLAGUE_ALIGNED\"]/event/choice[1]/text"
msgstr "调查噬魂仪式。"

#: src-en/data/events_special_storage.xml.append:4013
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/event/choice[@req=\"LIST_DDSOULPLAGUE_ALIGNED\"]/event/choice[1]/event/text"
msgstr ""
"噬魂仪式：\n"
"该仪式会为你提供一艘海盗船的位置，你可以将其击败，并将船上船员的灵魂献祭给距"
"离最近的灵魂瘟疫母体。作为回报，母体会赠予你它自身的灵魂，以若干随机的灵魂瘟"
"疫躯壳作为选择。你可以从中挑选一具躯壳留存。"

#: src-en/data/events_special_storage.xml.append:4016
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/event/choice[@req=\"LIST_DDSOULPLAGUE_ALIGNED\"]/event/choice[1]/event/choice[@req=\"pilot\"]/text"
msgstr "有意思。合上这本书。"

#: src-en/data/events_special_storage.xml.append:4022
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/event/choice[@req=\"LIST_DDSOULPLAGUE_ALIGNED\"]/event/choice[2]/text"
msgstr "调查魂织仪式。"

#: src-en/data/events_special_storage.xml.append:4024
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[8]/event/choice[@req=\"LIST_DDSOULPLAGUE_ALIGNED\"]/event/choice[2]/event/text"
msgstr ""
"魂织仪式：\n"
"该仪式允许你召唤并喂食一团灵魂瘟疫物质病毒，使其获得力量并成为躯壳编织者。执"
"行此仪式需要献祭1至2名人类的灵魂。若未能正确赋予病毒力量，它将会变得具有敌意"
"，且只会变异成为一具灵魂瘟疫躯壳。"

