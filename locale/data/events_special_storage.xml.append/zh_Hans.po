"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[@req=\"LIST_DDDARKEST_GAZE\"]/event/choice[@req=\"pilot\"]/text"
msgstr "合上这本书。"

#: src-en/data/events_special_storage.xml.append:4414
msgid ""
"data/events_special_storage.xml.append$//event[@name=\"STORAGE_CHECK_DARKGOD_CURSED_BOOK\"]/choice[@req=\"pilot\"]/text"
