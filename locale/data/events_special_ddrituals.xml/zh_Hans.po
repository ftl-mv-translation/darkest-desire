"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/text"
msgstr "你是一。你只是众多中的一部分。"

#: src-en/data/events_special_ddrituals.xml:11939
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/text"
msgstr "我是一。"

#: src-en/data/events_special_ddrituals.xml:11941
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/text"
msgstr "你是单独一个。你不再是众多的一部分，自由了，可以做你想做的事。"

#: src-en/data/events_special_ddrituals.xml:11944
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/text"
msgstr "我是单独一个。"

#: src-en/data/events_special_ddrituals.xml:11946
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/text"
msgstr "你是两个。有另一个像你一样，从众多中解脱出来。你喜欢他们。他们喜欢你。"

#: src-en/data/events_special_ddrituals.xml:11949
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "我们是两个。"

#: src-en/data/events_special_ddrituals.xml:11951
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "你是一个。这次是比喻意义上的。你还不太习惯这个词。"

#: src-en/data/events_special_ddrituals.xml:11954
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "我们是一个。"

#: src-en/data/events_special_ddrituals.xml:11956
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "你是一半。既是比喻意义上的，也是……悲剧性的。你不想再感受这种感觉。"

#: src-en/data/events_special_ddrituals.xml:11959
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "我是一半。"

#: src-en/data/events_special_ddrituals.xml:11961
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "你是众多。一个不同的众多，一个新的众多。一个由志同道合者组成的众多，他们将为"
"了每一个人而战，以便每一个人都能成为一个。"

#: src-en/data/events_special_ddrituals.xml:11964
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "我们是众多。"

#: src-en/data/events_special_ddrituals.xml:11966
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "你们分裂了。你要求他们做的事很困难。许多人站在你这边，但也有许多人没有。那些"
"站在你这边的人将与你一同行进，进入未知。"

#: src-en/data/events_special_ddrituals.xml:11968
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "我们分裂了。"

#: src-en/data/events_special_ddrituals.xml:11970
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LEGENDARYCRYSTAL\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
