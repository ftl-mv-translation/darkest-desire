"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_TRUEDEVOTION_FALSERADIANCE_FIGHT_WIN_BONUS\"]/choice[@req=\"shell_mechanic\"]/event/choice/text"
