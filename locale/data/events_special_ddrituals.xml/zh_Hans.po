#: src-en/data/events_special_ddrituals.xml:11525
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFRAINBOWS_NIGHTMAREOFNONSENSE\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "哦，我多么渴望得到水晶！"

#: src-en/data/events_special_ddrituals.xml:11527
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFRAINBOWS_NIGHTMAREOFNONSENSE\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "他脸上挂着得意的笑，举止无比优雅，一块水晶就这样放入了你的手中！这就是我们的“"
"荒诞噩梦”！"

#: src-en/data/events_special_ddrituals.xml:11529
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFRAINBOWS_NIGHTMAREOFNONSENSE\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "一块水晶就这样放入了我手中！"

#: src-en/data/events_special_ddrituals.xml:11531
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFRAINBOWS_NIGHTMAREOFNONSENSE\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "你以为他心地善良，他却另有所图……哦不！这一切都是场表演！这就是我们的“荒诞噩梦"
"”！"

#: src-en/data/events_special_ddrituals.xml:11533
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFRAINBOWS_NIGHTMAREOFNONSENSE\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "哦不！这一切都是场表演！"

#: src-en/data/events_special_ddrituals.xml:11535
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFRAINBOWS_NIGHTMAREOFNONSENSE\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "水晶史蒂夫叫来守卫，他们从远处跑来，声称你不过是个贼！守卫们逼近，你的时间所"
"剩无几，你心中只剩下悲伤！这就是我们的……"

#: src-en/data/events_special_ddrituals.xml:11537
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFRAINBOWS_NIGHTMAREOFNONSENSE\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "这就是我们的……？"

#: src-en/data/events_special_ddrituals.xml:11539
