msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFMARTYRDOM_GRAVEYARDOFDRAGONS\"]/choice/event/choice/event/choice/text"
