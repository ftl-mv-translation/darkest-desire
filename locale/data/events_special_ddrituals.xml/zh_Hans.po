#: src-en/data/events_special_ddrituals.xml:11580
msgid ""
"data/events_special_ddrituals.xml$//event[@name=\"DDRITUALS_QUESTS_LIST_CRYSTALOFRAINBOWS_SEAOFSOLITUDE\"]/choice/event/choice/event/text"
