msgstr ""

#: src-en/data/events_enlightened.xml:4387
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr ""

#: src-en/data/events_enlightened.xml:4393
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "那到底是什么东西？你到底是谁？"

#: src-en/data/events_enlightened.xml:4395
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr ""
"一阵熟悉的笑声在整个房间里回荡，你的心脏猛地一跳。这一定就是你一直在对话的那"
"个声音。那个把你引到这里、引到这艘飞船上的声音……引向那块充满痛苦与谎言的碎片"
"的声音。"

#: src-en/data/events_enlightened.xml:4397
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "你……你是不是早就知道会这样？关于那块该死的碎片？它现在到底在哪儿？"

#: src-en/data/events_enlightened.xml:4399
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr ""

#: src-en/data/events_enlightened.xml:4403
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "我……我明白了。也许我待在这儿，快要被逼疯了。"

#: src-en/data/events_enlightened.xml:4405
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr ""
"“哦……好吧，你可别在我这儿变得太疯了，有趣的家伙。风趣是一回事，可是……疯了？我"
"绝对不可能……为一个疯子做事。那……可就一点都不好玩了，不是吗？”"

#: src-en/data/events_enlightened.xml:4407
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/text"
msgstr "是啊，这说得通……等等，你说什么？"

#: src-en/data/events_enlightened.xml:4409
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr ""
"你四周的笑声变得喧闹起来，那位戴着面具的深渊潜者躬身行礼，“哦……可别让我忘了自"
"我介绍。我是……启蒙者中的一位长老，愿……为您效劳，最有趣的阁下。我……是一名贡礼"
"塑形者，我的族人都这么称呼我。您帮我……从那个疯癫偷窃的疯子手里夺回了我心爱的"
"面具，而且……嗯，我可不是那种欠债不还的人。”"

#: src-en/data/events_enlightened.xml:4410
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/crewMember"
msgstr "弄臣"

#: src-en/data/events_enlightened.xml:4412
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/text"
msgstr "那么，那个面具……我们就是为了这个才来这里的？它到底是什么东西？"

#: src-en/data/events_enlightened.xml:4414
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/event/text"
msgstr ""

#: src-en/data/events_enlightened.xml:4419
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/event/choice/text"
msgstr "好吧，我大概明白了。既然你并不是特别信奉那种全能神祇的一套，这面具对你来说为"
"什么还这么重要？"

#: src-en/data/events_enlightened.xml:4421
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/event/choice/event/text"
msgstr "房间里传来一阵轻笑声，贡礼塑形者向后仰头，“哦……好吧，这不只是一枚荣誉徽章。它"
"同时……还能作为操控人类灵魂的媒介。”"

#: src-en/data/events_enlightened.xml:4423
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/event/choice/event/choice/text"
msgstr "啥？"

#: src-en/data/events_enlightened.xml:4425
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/event/choice/event/choice/event/text"
msgstr "随着他一声响指，一个漂浮不定、虚幻缥缈的身影出现在你身旁……"

#: src-en/data/events_enlightened.xml:4428
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/event/choice/event/choice/event/choice/text"
msgstr "在极度的恐惧中尖叫。"

#: src-en/data/events_enlightened.xml:4430
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/event/choice/event/choice/event/choice/event/text"
msgstr ""
"……紧接着又是一声响指，第二个相似的虚影浮现出来。你吓得连连后退，失声尖叫，而"
"你周围的轻笑声很快又变成了一片刺耳的嘲弄。“哦……别表现得这么惊讶嘛，有趣的家伙"
"。除非你……是在故意逗乐？哦，这可真……聪明。你真是个机灵的小家伙，有趣的人。”你"
"露出困惑又恼怒的神情，而那位贡礼塑形者只是大笑着走出了房间……他身后紧跟着那队"
"由灵魂组成的随行虚影。"

#: src-en/data/events_enlightened.xml:4433
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and @lvl=\"0\"]/event/choice/event/choice/event/choice/event/choice/text"
msgstr "我……得找个时间喝一杯。"

#: src-en/data/events_enlightened.xml:4435
msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice[@req=\"BLUELIST_DDTRIBUTE_MASKS\""
" and "
"@lvl=\"0\"]/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr ""
"你心里清楚，你确实得喝一杯了。这一切……简直是一团糟。从贡礼塑形者的嘲弄，到联"
"邦飞船上的种种恐怖，再到那块神秘碎片带来的幻象……你感觉那金色印记依然清晰地浮"
"现在眼前。不过好在还有一丝慰藉——此刻一切归于平静，而且你还结交了一位强大的盟"
"友。"

#: src-en/data/events_enlightened.xml:4437
msgid ""
