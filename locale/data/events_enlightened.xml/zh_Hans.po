"data/events_enlightened.xml$//event[@name=\"ITEMS_ENLIGHTENED_FUELDUEL\"]/choice[1]/event/text"
msgstr "你正准备做某件事，这时收到了来自虚空的通讯……你要接听吗？"

#: src-en/data/events_enlightened.xml:2421
msgid ""
"data/events_enlightened.xml$//event[@name=\"ITEMS_ENLIGHTENED_FUELDUEL\"]/choice[1]/event/choice[1]/text"
