#: src-en/data/events_enlightened.xml:2659
msgid ""
"data/events_enlightened.xml$//event[@name=\"ITEMS_ENLIGHTENED_FUELDUEL\"]/choice[2]/event/choice[2]/event/choice[2]/text"
msgstr "跳过。"

