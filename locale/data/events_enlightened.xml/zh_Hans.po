msgid ""
"data/events_enlightened.xml$//event[@name=\"NEUTRAL_ENLIGHTENED_PALADIN_CRUSADE_SHIP_WIN\"]/choice[1]/event/choice[2]/event/choice[@req=\"LIST_CREW_HAPPYHOLIDAYS\"]/event/text"
