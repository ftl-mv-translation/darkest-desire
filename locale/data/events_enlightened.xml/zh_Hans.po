#: src-en/data/events_enlightened.xml:2769
msgid ""
"data/events_enlightened.xml$//event[@name=\"ITEMS_ENLIGHTENED_ENGI_INVESTIGATION\"]/choice/event/choice[1]/event/choice[1]/event/choice/event/choice[2]/event/choice[1]/text"
msgstr "好的，我不会告诉任何人。"

#: src-en/data/events_enlightened.xml:2771
