#: src-en/data/events_enlightened.xml:3937
msgid ""
"data/events_enlightened.xml$//event[@name=\"DISTRESS_ENLIGHTENED_SHELL_RESEARCH\"]/choice[1]/event/choice/event/choice[5]/text"
