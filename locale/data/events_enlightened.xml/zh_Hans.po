msgid ""
"data/events_enlightened.xml$//event[@name=\"DDENLIGHTENED_ECHOEDDREAM_QUEST_FIGHT_WIN\"]/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/choice/event/text"
msgstr "..."

